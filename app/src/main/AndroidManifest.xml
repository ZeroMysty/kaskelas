<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KasKelasApp"
        tools:targetApi="31">

        <activity
            android:name=".ui.auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ui.auth.RoleSelectionActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".ui.auth.RegisterBendaharaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".ui.auth.LoginBendaharaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <activity
            android:name=".ui.auth.RegisterSiswaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />
        
        <activity
            android:name=".ui.auth.OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />


        <!-- Main Activity (Beranda) - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KasKelasApp"
            android:screenOrientation="portrait" />

        <!-- Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.members.AnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Tambah Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.members.TambahAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.members.AnggotaActivity" />

        <!-- Edit Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.members.EditAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.members.AnggotaActivity" />



        <!-- Tambah Pemasukan Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.transactions.TambahPemasukanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Tambah Pengeluaran Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.transactions.TambahPengeluaranActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Detail Pemasukan Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.transactions.DetailPemasukanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.history.RiwayatActivity" />

        <!-- Detail Pengeluaran Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.transactions.DetailPengeluaranActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.history.RiwayatActivity" />

        <!-- Riwayat Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".ui.history.RiwayatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- KHUSUS Chart Detail - DIKUNCI LANDSCAPE -->
        <activity
            android:name=".ui.chart.ChartDetailActivity"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize" />

        <!-- Settings Activity -->
        <activity
            android:name=".ui.settings.SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.main.MainActivity" />

        <!-- Detail Anggota Activity -->
        <activity
            android:name=".ui.members.DetailAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.main.MainActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
