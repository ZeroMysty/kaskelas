<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KasKelasApp"
        tools:targetApi="31">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity (Beranda) - DIKUNCI PORTRAIT -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KasKelasApp"
            android:screenOrientation="portrait" />

        <!-- Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".AnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- Tambah Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".TambahAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".AnggotaActivity" />

        <!-- Edit Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".EditAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".AnggotaActivity" />

        <!-- Pemasukan Anggota Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".PemasukanAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".AnggotaActivity" />

        <!-- Tambah Pemasukan Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".TambahPemasukanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- Tambah Pengeluaran Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".TambahPengeluaranActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- Detail Pemasukan Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".DetailPemasukanActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".RiwayatActivity" />

        <!-- Detail Pengeluaran Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".DetailPengeluaranActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".RiwayatActivity" />

        <!-- Riwayat Activity - DIKUNCI PORTRAIT -->
        <activity
            android:name=".RiwayatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- KHUSUS Chart Detail - DIKUNCI LANDSCAPE -->
        <activity
            android:name=".ChartDetailActivity"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize" />

        <!-- Settings Activity -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

        <!-- Detail Anggota Activity -->
        <activity
            android:name=".DetailAnggotaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:parentActivityName=".MainActivity" />

    </application>

</manifest>