<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardOnboardingImage"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:cardBackgroundColor="#00000000"
        app:cardCornerRadius="100dp"
        app:cardElevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_glass_card">

            <ImageView
                android:id="@+id/ivOnboardingIcon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_wallet"
                app:tint="@color/brand_primary" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvOnboardingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:text="Selamat Datang"
        android:textColor="@color/text_main"
        android:textSize="28sp" />

    <TextView
        android:id="@+id/tvOnboardingDesc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:alpha="0.6"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="Kelola uang kas kelompokmu dengan lebih mudah dan transparan."
        android:textColor="@color/text_main"
        android:textSize="16sp" />

</LinearLayout>

