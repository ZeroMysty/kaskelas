<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <include layout="@layout/layout_animated_background" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="110dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/headerRiwayat"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/margin_main"
                android:paddingTop="15dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Riwayat Transaksi"
                    android:textColor="@color/text_main"
                    android:textSize="@dimen/text_h1"
                    android:fontFamily="sans-serif-black" />
                <ImageButton
                    android:id="@+id/btnExportRiwayat"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_glass_card"
                    android:backgroundTint="#202196F3"
                    android:padding="11dp"
                    android:src="@drawable/ic_share"
                    app:tint="@color/brand_primary" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginTop="4dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_balance_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical">
                        <TextView
                            android:text="Saldo Terkini"
                            android:textColor="@color/text_white"
                            android:textSize="12sp"
                            android:alpha="0.8"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:id="@+id/tvTotalBalanceRiwayat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="Rp 0"
                            android:textColor="@color/text_white"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="60dp"
                        android:layout_marginHorizontal="16dp"
                        android:alpha="0.2"
                        android:background="@color/text_white" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:text="↑ Masuk"
                            android:textColor="@color/text_white"
                            android:textSize="11sp"
                            android:alpha="0.7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:id="@+id/tvTotalMasukRiwayat"
                            android:text="Rp 0"
                            android:textColor="@color/text_white"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="8dp"
                            android:alpha="0.2"
                            android:background="@color/text_white" />
                        <TextView
                            android:text="↓ Keluar"
                            android:textColor="@color/text_white"
                            android:textSize="11sp"
                            android:alpha="0.7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                        <TextView
                            android:id="@+id/tvTotalKeluarRiwayat"
                            android:text="Rp 0"
                            android:textColor="@color/text_white"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card">
                    <ImageView
                        android:id="@+id/ivSearchIconRiwayat"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="18dp"
                        android:alpha="0.35"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_main" />
                    <EditText
                        android:id="@+id/etSearchRiwayat"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_toEndOf="@+id/ivSearchIconRiwayat"
                        android:background="@null"
                        android:hint="Cari transaksi..."
                        android:paddingStart="10dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_sub"
                        android:textSize="@dimen/text_body"
                        android:singleLine="true" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRiwayat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="4dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />
</FrameLayout>
