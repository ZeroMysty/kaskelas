<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Texture Layer: Subtle Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#08000000" />

    <!-- Shape 1: Diagonal Top Right (Large Blob) -->
    <View
        android:id="@+id/bg_shape_1"
        android:layout_width="450dp"
        android:layout_height="650dp"
        android:layout_gravity="end|top"
        android:layout_marginEnd="-180dp"
        android:layout_marginTop="-220dp"
        android:background="@drawable/bg_abstract_shape_1"
        android:alpha="0.8"
        android:rotation="-35" />

    <!-- Shape 2: Bottom Left Glow (Soft Blob) -->
    <View
        android:id="@+id/bg_shape_2"
        android:layout_width="350dp"
        android:layout_height="350dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-120dp"
        android:layout_marginBottom="-70dp"
        android:background="@drawable/bg_abstract_shape_2"
        android:alpha="0.7" />

    <!-- Shape 3: Floating Circle Middle -->
    <View
        android:id="@+id/bg_shape_3"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center"
        android:layout_marginStart="120dp"
        android:background="@drawable/bg_abstract_shape_2"
        android:alpha="0.6" />

    <!-- Shape 4: Top Left Accent (Geometric Square) -->
    <View
        android:id="@+id/bg_shape_4"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="30dp"
        android:layout_marginTop="120dp"
        android:background="@drawable/bg_geometric_shape"
        android:alpha="0.3"
        android:rotation="20" />

    <!-- Shape 5: Bottom Right Geometric -->
    <View
        android:id="@+id/bg_shape_5"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="50dp"
        android:layout_marginBottom="180dp"
        android:background="@drawable/bg_geometric_shape"
        android:alpha="0.25"
        android:rotation="-25" />

    <!-- Shape 6: Floating Accent Circle -->
    <View
        android:id="@+id/bg_shape_6"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_abstract_shape_2"
        android:alpha="0.4" />

    <!-- Shape 7: Tiny Geometric Particle -->
    <View
        android:id="@+id/bg_shape_7"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="80dp"
        android:background="@drawable/bg_geometric_shape"
        android:alpha="0.2"
        android:rotation="45" />

</FrameLayout>

