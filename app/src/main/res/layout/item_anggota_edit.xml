<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="#00000000"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <!-- Avatar Inisial -->
        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_avatar">

            <TextView
                android:id="@+id/tvAvatarInisialEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="A"
                android:textColor="#2563EB"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black" />
        </FrameLayout>

        <!-- Info Anggota -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_toEndOf="@+id/avatarContainer"
            android:layout_toStartOf="@+id/ivArrow"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaAnggotaEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Anggota"
                android:textColor="@color/text_main"
                android:textSize="14sp"
                android:fontFamily="sans-serif-bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvIdAnggotaEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:alpha="0.45"
                android:text="ID: 001"
                android:textColor="@color/text_main"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Panah Kanan -->
        <ImageView
            android:id="@+id/ivArrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:alpha="0.25"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/text_main" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>