<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer for Header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <!-- Profile Focus Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="30dp">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/bg_glass_card"
                    android:backgroundTint="#202196F3" />

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="-60dp"
                    android:src="@drawable/ic_nav_members"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:alpha="0.6"
                    android:text="Ubah Data Anggota"
                    android:textColor="@color/text_main"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="Biodata Update"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_h2"
                        android:fontFamily="sans-serif-bold" />

                    <!-- Input Nama -->
                    <EditText
                        android:id="@+id/etEditNama"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_input_putih"
                        android:hint="Nama Lengkap"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_body" />

                    <!-- Input NIS -->
                    <EditText
                        android:id="@+id/etEditNis"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="32dp"
                        android:background="@drawable/bg_input_putih"
                        android:hint="NIS"
                        android:inputType="number"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_body" />

                    <Button
                        android:id="@+id/btnSimpanEdit"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginBottom="12dp"
                        android:backgroundTint="@color/brand_primary"
                        android:text="Simpan Perubahan"
                        android:textAllCaps="false"
                        android:textColor="@color/text_white"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-bold"
                        app:cornerRadius="20dp" />

                    <Button
                        android:id="@+id/btnHapusAnggota"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Hapus Anggota"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_danger"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_main"
        android:paddingTop="@dimen/header_top_padding">

        <ImageButton
            android:id="@+id/btnBackEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Edit Anggota"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_h1"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</FrameLayout>
