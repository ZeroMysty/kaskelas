<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Lingkaran dekoratif lembut di background (opsional untuk kesan premium) -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_pill_blue"
        android:alpha="0.05"
        app:layout_constraintCircleRadius="200dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="-100dp"
        android:layout_marginTop="-100dp" />

    <!-- Container Logo dengan Shadow -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLogoSplash"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:cardCornerRadius="60dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivLogoSplash"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_wallet"
            app:tint="#2196F3" />
    </androidx.cardview.widget.CardView>

    <!-- Nama Aplikasi dengan Style Branding -->
    <LinearLayout
        android:id="@+id/layoutTextSplash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardLogoSplash">

        <TextView
            android:id="@+id/tvAppNameSplash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            android:text="KASKELAS"
            android:textColor="#1A1A1A"
            android:textSize="36sp" />

        <TextView
            android:id="@+id/tvTaglineSplash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.1"
            android:text="KELOLA KAS JADI LEBIH MUDAH"
            android:textColor="#888888"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Info Versi di Bawah -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="v1.0.0"
        android:textColor="#BBBBBB"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
