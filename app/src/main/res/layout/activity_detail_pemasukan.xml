<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <include layout="@layout/layout_animated_background" />
    
    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer for Header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <!-- Amount Display Area -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.5"
                        android:text="Total Pemasukan"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tvDetailJumlahP"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Rp 0"
                        android:textColor="@color/brand_accent"
                        android:textSize="42sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Detail Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card_lg">

                    <!-- Field: Nama -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.4"
                            android:text="NAMA TRANSAKSI"
                            android:textColor="@color/text_main"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:id="@+id/tvDetailNamaP"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="-"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_body"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:alpha="0.1"
                        android:background="@color/text_main" />

                    <!-- Field: Tanggal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.4"
                            android:text="TANGGAL"
                            android:textColor="@color/text_main"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:id="@+id/tvDetailTanggalP"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="-"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:alpha="0.1"
                        android:background="@color/text_main" />

                    <!-- Field: Keterangan -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.4"
                            android:text="KETERANGAN"
                            android:textColor="@color/text_main"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:id="@+id/tvDetailKeteranganP"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:minHeight="40dp"
                            android:text="-"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_body" />
                    </LinearLayout>

                    <!-- Tombol Selesai -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSelesaiDetailP"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_action_height"
                        android:layout_marginTop="32dp"
                        android:background="@drawable/bg_btn_green"
                        android:text="Selesai"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_accent"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_main"
        android:paddingTop="@dimen/header_top_padding">

        <ImageButton
            android:id="@+id/btnBackDetailP"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_glass_card"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Detail Transaksi"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_h1"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</FrameLayout>
