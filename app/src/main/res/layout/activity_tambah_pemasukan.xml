<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer for Header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <!-- Amount Focus Area -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.5"
                        android:text="Jumlah Pemasukan"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="sans-serif-medium" />

                    <EditText
                        android:id="@+id/etJumlahPemasukan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:hint="Rp 0"
                        android:inputType="number"
                        android:textColor="@color/brand_accent"
                        android:textColorHint="#2016A34A"
                        android:textSize="42sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="Informasi Transaksi"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_h2"
                        android:fontFamily="sans-serif-black" />

                    <!-- Input Nama -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="NAMA TRANSAKSI"
                        android:textColor="@color/text_main"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />
                    <EditText
                        android:id="@+id/etNamaPemasukan"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_input_putih"
                        android:hint="Contoh: Iuran Kas"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_sub"
                        android:textSize="@dimen/text_body"
                        android:singleLine="true" />

                    <!-- Input Keterangan -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="KETERANGAN (OPSIONAL)"
                        android:textColor="@color/text_main"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />
                    <EditText
                        android:id="@+id/etKeteranganPemasukan"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="32dp"
                        android:background="@drawable/bg_input_putih"
                        android:gravity="top"
                        android:hint="Tambahkan catatan..."
                        android:padding="16dp"
                        android:textColor="@color/text_main"
                        android:textColorHint="@color/text_sub"
                        android:textSize="@dimen/text_body" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnSimpanPemasukan"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_action_height"
                        android:background="@drawable/bg_btn_green"
                        android:text="Simpan Pemasukan"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_accent"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_main"
        android:paddingTop="@dimen/header_top_padding">

        <ImageButton
            android:id="@+id/btnBackPemasukan"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_glass_card"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Pemasukan Baru"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_h1"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</FrameLayout>