<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <include layout="@layout/layout_animated_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerChartDetail"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/margin_main"
            android:paddingTop="15dp">

            <ImageButton
                android:id="@+id/btnBackChart"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_glass_card"
                android:padding="11dp"
                android:src="@drawable/ic_back"
                app:tint="@color/text_main" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Statistik"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_h1"
                android:fontFamily="sans-serif-black" />

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="19dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_glass_card"
                    android:paddingHorizontal="8dp">
                    <Spinner
                        android:id="@+id/spinnerFilterWaktu"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:backgroundTint="@color/text_main"
                        android:minWidth="120dp" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <com.github.mikephil.charting.charts.BarChart
            android:id="@+id/fullBarChart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</FrameLayout>
