<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <include layout="@layout/layout_animated_background" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/margin_main"
            android:paddingTop="@dimen/header_top_padding">

            <ImageButton
                android:id="@+id/btnBackKonfirmasi"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_glass_card"
                android:padding="10dp"
                android:src="@drawable/ic_back"
                app:tint="@color/text_main" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Konfirmasi Pembayaran"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_h1"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvKonfirmasi"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="@dimen/margin_main" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvEmptyKonfirmasi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Semua pembayaran sudah dikonfirmasi"
        android:textColor="@color/text_sub"
        android:visibility="gone" />

</FrameLayout>
