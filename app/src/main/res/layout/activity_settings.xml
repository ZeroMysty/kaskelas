<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayoutSettings"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main">

        <include layout="@layout/layout_animated_background" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="110dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Scrollable Header -->
                <LinearLayout
                    android:id="@+id/headerSettings"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/header_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/margin_main"
                    android:paddingTop="@dimen/header_top_padding">
                    
                    <ImageButton
                        android:id="@+id/btnMenuSettings"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/bg_glass_card"
                        android:padding="10dp"
                        android:src="@drawable/ic_menu"
                        android:visibility="gone"
                        app:tint="@color/text_main" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pengaturan"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_h1"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <!-- Profile Header Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="32dp">

                    <FrameLayout
                        android:layout_width="86dp"
                        android:layout_height="86dp"
                        android:background="@drawable/bg_avatar">

                        <ImageView
                            android:id="@+id/ivProfileBendahara"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_members"
                            app:tint="@color/brand_primary" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tvNamaBendahara"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Budi (Bendahara)"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_h2"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvKelasInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.5"
                        android:text="XII IPA 1"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_caption"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Pengaturan Kas Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_main"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#00000000"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_card_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            android:text="Preferensi Kas"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_h2"
                            android:fontFamily="sans-serif-black" />

                        <!-- Nominal Label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.4"
                            android:text="NOMINAL KAS DEFAULT"
                            android:textColor="@color/text_main"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <EditText
                            android:id="@+id/etNominalDefault"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="20dp"
                            android:background="@drawable/bg_input_putih"
                            android:hint="Rp 0"
                            android:inputType="number"
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_body"
                            android:singleLine="true" />

                        <!-- Interval Label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.4"
                            android:text="INTERVAL PEMBAYARAN"
                            android:textColor="@color/text_main"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="20dp"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">
                            <AutoCompleteTextView
                                android:id="@+id/spinnerInterval"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_input_putih"
                                android:inputType="none"
                                android:paddingHorizontal="16dp"
                                android:text="Mingguan"
                                android:textColor="@color/text_main"
                                android:textSize="@dimen/text_body" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- E-Wallet Label -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.4"
                            android:text="E-WALLET PENERIMAAN"
                            android:textColor="@color/text_main"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.1" />
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp">
                            <AutoCompleteTextView
                                android:id="@+id/spinnerEwalletSettings"
                                android:layout_width="match_parent"
                                android:layout_height="52dp"
                                android:background="@drawable/bg_input_putih"
                                android:inputType="none"
                                android:paddingHorizontal="16dp"
                                android:text="DANA"
                                android:textColor="@color/text_main"
                                android:textSize="@dimen/text_body" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Personalisasi UI Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_main"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#00000000"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_card_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:text="Antarmuka"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_h2"
                            android:fontFamily="sans-serif-black" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Gaya Navigasi Sidebar"
                                    android:textColor="@color/text_main"
                                    android:textSize="14sp"
                                    android:fontFamily="sans-serif-bold" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Gunakan Hamburger Menu"
                                    android:textColor="@color/text_sub"
                                    android:textSize="12sp" />
                            </LinearLayout>
                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchNavStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumbTint="@color/brand_primary"
                                app:trackTint="@color/brand_primary_light" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Ekspor Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_main"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#00000000"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_card_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:text="Laporan &amp; Data"
                            android:textColor="@color/text_main"
                            android:textSize="@dimen/text_h2"
                            android:fontFamily="sans-serif-black" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnConnectSpreadsheet"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/btn_action_height"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_btn_outline"
                            android:text="Google Sheets"
                            android:textAllCaps="false"
                            android:textColor="@color/brand_primary"
                            android:fontFamily="sans-serif-bold" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnExportReport"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/btn_action_height"
                            android:background="@drawable/bg_btn_green"
                            android:text="Ekspor Laporan PDF"
                            android:textAllCaps="false"
                            android:textColor="@color/text_white"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Danger Zone -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/margin_main"
                    app:cardBackgroundColor="#00000000"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_card_lg">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:text="Zona Bahaya"
                            android:textColor="@color/brand_danger"
                            android:textSize="@dimen/text_h2"
                            android:fontFamily="sans-serif-black" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnResetData"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/btn_action_height"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_btn_outline"
                            android:text="Tutup Buku / Reset"
                            android:textAllCaps="false"
                            android:textColor="@color/brand_danger"
                            android:fontFamily="sans-serif-bold" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnLogout"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/btn_action_height"
                            android:background="@drawable/bg_btn_green"
                            android:backgroundTint="@color/brand_danger"
                            android:text="Logout Akun"
                            android:textAllCaps="false"
                            android:textColor="@color/text_white"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <include
            android:id="@+id/bottomNavContainer"
            layout="@layout/layout_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom" />

        <View
            android:id="@+id/blurOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000"
            android:visibility="gone" />

    </FrameLayout>

    <include layout="@layout/layout_side_nav" />

</androidx.drawerlayout.widget.DrawerLayout>

