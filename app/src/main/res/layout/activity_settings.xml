<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <include layout="@layout/animated_background" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="110dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/headerSettings"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/margin_main"
                android:paddingTop="15dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengaturan"
                    android:textColor="@color/text_main"
                    android:textSize="@dimen/text_h1"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginTop="4dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Preferensi Pembayaran"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_h2"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:alpha="0.6"
                        android:text="Nominal default untuk pembayaran cepat."
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_caption" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnNominal2"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_outline_button"
                            android:text="2.000"
                            android:textAllCaps="false"
                            android:textColor="@color/brand_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            app:backgroundTint="@null" />

                        <Button
                            android:id="@+id/btnNominal5"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="3dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_outline_button"
                            android:text="5.000"
                            android:textAllCaps="false"
                            android:textColor="@color/brand_primary"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            app:backgroundTint="@null" />

                        <Button
                            android:id="@+id/btnNominalLainnya"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1.2"
                            android:background="@drawable/bg_outline_button"
                            android:text="Lainnya"
                            android:textAllCaps="false"
                            android:textColor="@color/text_main"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-bold"
                            app:backgroundTint="@null" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etNominalCustom"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_input_putih"
                        android:hint="Masukkan nominal..."
                        android:inputType="number"
                        android:paddingHorizontal="24dp"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_body"
                        android:visibility="gone" />

                    <Button
                        android:id="@+id/btnSimpanSettings"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="24dp"
                        android:backgroundTint="@color/brand_accent"
                        android:text="Simpan Perubahan"
                        android:textAllCaps="false"
                        android:textColor="@color/text_white"
                        android:fontFamily="sans-serif-bold"
                        app:cornerRadius="20dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_red"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-bold"
                        android:text="Manajemen Data"
                        android:textColor="@color/brand_danger"
                        android:textSize="@dimen/text_h2" />

                    <Button
                        android:id="@+id/resetData"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_outline_button_danger"
                        android:text="Reset Semua Data"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_danger"
                        android:fontFamily="sans-serif-bold"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        layout="@layout/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</FrameLayout>