<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer for Header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <!-- Profile Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/brand_primary"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_balance_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <ImageView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_glass_card"
                        android:padding="12dp"
                        android:src="@drawable/ic_nav_members"
                        app:tint="@color/white" />

                    <TextView
                        android:id="@+id/tvNamaDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Nama Anggota"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNisDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.8"
                        android:text="NIS: 123456"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvPhoneDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.8"
                        android:text="0812-3456-7890"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <!-- Tombol WA -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHubungiWA"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Tagih via WhatsApp"
                        android:textColor="@color/brand_primary"
                        android:textStyle="bold"
                        app:backgroundTint="@color/white"
                        app:cornerRadius="20dp"
                        app:icon="@drawable/ic_nav_history"
                        app:iconTint="@color/brand_primary" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/labelRiwayat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginTop="40dp"
                android:text="Riwayat Pembayaran"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_h2"
                android:fontFamily="sans-serif-black" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRiwayatAnggota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_main"
        android:paddingTop="@dimen/header_top_padding">

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Profil Anggota"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_h1"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</FrameLayout>


