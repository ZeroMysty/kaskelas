<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background">

    <!-- Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Spacer for Header -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            <!-- Profile Info Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfileInfo"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginHorizontal="@dimen/margin_main"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_balance_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="35dp">

                    <TextView
                        android:id="@+id/tvNamaDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Anggota"
                        android:textColor="@color/text_white"
                        android:textSize="28sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvNisDetail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:alpha="0.8"
                        android:text="NIS: 123456"
                        android:textColor="@color/text_white"
                        android:textSize="@dimen/text_body" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/labelRiwayat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginTop="40dp"
                android:text="Riwayat Pembayaran"
                android:textColor="@color/text_main"
                android:textSize="@dimen/text_h2"
                android:fontFamily="sans-serif-black" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRiwayatAnggota"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="4dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/margin_main"
        android:paddingTop="@dimen/header_top_padding">

        <ImageButton
            android:id="@+id/btnBackDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Profil Anggota"
            android:textColor="@color/text_main"
            android:textSize="@dimen/text_h1"
            android:fontFamily="sans-serif-black" />
    </LinearLayout>

</FrameLayout>
