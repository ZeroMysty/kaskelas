<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main">

    <include layout="@layout/layout_animated_background" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="110dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Scrollable Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/header_height"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/margin_main"
                android:paddingTop="@dimen/header_top_padding">

                <ImageButton
                    android:id="@+id/btnBackProfileSiswa"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/text_main" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Profil Saya"
                    android:textColor="@color/text_main"
                    android:textSize="@dimen/text_h1"
                    android:fontFamily="sans-serif-black" />
            </LinearLayout>

            <!-- Profile Focus Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingVertical="32dp">

                <FrameLayout
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:background="@drawable/bg_avatar">

                    <ImageView
                        android:id="@+id/ivProfileSiswaPage"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_nav_members"
                        app:tint="@color/brand_primary" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvNamaSiswaProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Budi Santoso"
                    android:textColor="@color/text_main"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:id="@+id/tvKelasSiswaProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.5"
                    android:text="Kelas: XII IPA 1 (Absen 08)"
                    android:textColor="@color/text_main"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Main Form Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_main"
                app:cardBackgroundColor="#00000000"
                app:cardCornerRadius="@dimen/radius_card"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_card_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="Biodata Update"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_h2"
                        android:fontFamily="sans-serif-black" />

                    <!-- Email Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="EMAIL AKTIF"
                        android:textColor="@color/text_main"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />
                    <EditText
                        android:id="@+id/etEmailSiswaProfile"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="20dp"
                        android:background="@drawable/bg_input_putih"
                        android:hint="budi@student.com"
                        android:inputType="textEmailAddress"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_body"
                        android:singleLine="true" />

                    <!-- Phone Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="NOMOR TELEPON (WA)"
                        android:textColor="@color/text_main"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.1" />
                    <EditText
                        android:id="@+id/etPhoneSiswaProfile"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="32dp"
                        android:background="@drawable/bg_input_putih"
                        android:hint="08123456789"
                        android:inputType="phone"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_main"
                        android:textSize="@dimen/text_body"
                        android:singleLine="true" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnUpdateProfileSiswa"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_action_height"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_btn_green"
                        android:backgroundTint="@color/brand_primary"
                        android:text="Simpan Perubahan"
                        android:textAllCaps="false"
                        android:textColor="@color/text_white"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-bold" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnLogoutSiswa"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/btn_action_height"
                        android:text="Keluar Akun"
                        android:textAllCaps="false"
                        android:textColor="@color/brand_danger"
                        android:textSize="@dimen/text_body"
                        android:fontFamily="sans-serif-bold" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom" />

</FrameLayout>
