<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Profile Header Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="120dp"
                android:paddingBottom="24dp">

                <ImageView
                    android:id="@+id/ivProfileSiswa"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="20dp"
                    android:src="@drawable/ic_nav_members"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvNamaSiswaProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Budi Setiawan"
                    android:textColor="@color/text_main"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNisSiswaProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="NIS: 12345678"
                    android:textColor="@color/text_sub"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvKelasSiswaProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pill_green"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="Kelas XII IPA 1"
                    android:textColor="@color/brand_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#1AE53935"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Pengaturan Akun"
                        android:textColor="@color/brand_danger"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogoutSiswa"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Keluar Akun (Logout)"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/brand_danger"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Floating Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp">

        <ImageButton
            android:id="@+id/btnBackProfileSiswa"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_glass_card"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_main" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Profil Siswa"
            android:textColor="@color/text_main"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>

