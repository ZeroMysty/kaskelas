<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.KasKelasApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!--    Splash Screen    -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/splashscreen</item>
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="postSplashScreenTheme">@style/Theme.KasKelasApp</item>
    </style>

    <style name="Theme.KasKelasApp" parent="Base.Theme.KasKelasApp" />
</resources>