<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dasar: Abu-biru sangat muda yang lebih solid -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F8FAFC"
                android:endColor="#F1F5F9"
                android:angle="270" />
        </shape>
    </item>

    <!-- Aura Indigo Lembut di Pojok Kanan Atas (Lebih Terlihat) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="700dp"
                android:centerX="90%"
                android:centerY="10%"
                android:startColor="#256366F1"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Aura Teal/Emerald Lembut di Pojok Kiri Bawah (Lebih Terlihat) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="10%"
                android:centerY="90%"
                android:startColor="#2010B981"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Aksen Cahaya di Tengah -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="800dp"
                android:centerX="50%"
                android:centerY="50%"
                android:startColor="#10FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
