<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Solid -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:endColor="#F1F5F9"
                android:startColor="#FFFFFF" />
        </shape>
    </item>

    <!-- Top Left Accent -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="0%"
                android:centerY="0%"
                android:endColor="#00000000"
                android:gradientRadius="600dp"
                android:startColor="#153B82F6"
                android:type="radial" />
        </shape>
    </item>

    <!-- Bottom Right Accent -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:centerX="100%"
                android:centerY="100%"
                android:endColor="#00000000"
                android:gradientRadius="600dp"
                android:startColor="#1010B981"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
